# Lumen environment template
# Copy to .env and fill in. NEVER commit .env.
#
# Network selection: "atlantic" (testnet, chainId 688689) or "pacific" (mainnet, chainId 1672)
LUMEN_NETWORK=atlantic

# RPC override (optional — defaults come from assets/networks.json)
# LUMEN_RPC_URL=https://atlantic.dplabs-internal.com

# Sender configuration. Use exactly ONE of:
#   1. LUMEN_KEYSTORE  — path to encrypted keystore JSON (recommended)
#   2. LUMEN_ACCOUNT   — cast-managed account name (cast wallet import …)
#   3. LUMEN_PRIVATE_KEY — raw hex key (NOT recommended; testnet only)
# LUMEN_KEYSTORE=$HOME/.lumen/keys/sender.json
# LUMEN_ACCOUNT=lumen-sender
# LUMEN_PRIVATE_KEY=0xchange-me

# Optional: explorer base for receipt links (defaults from networks.json)
# LUMEN_EXPLORER_URL=https://atlantic.pharosscan.xyz
